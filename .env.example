NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
RESEND_API_KEY=re_YOUR_KEY
CRON_SECRET=a_long_random_string_used_by_vercel_cron
APP_URL=http://localhost:3000
ADMIN_EMAILS=admin1@example.com,admin2@example.com

# Optional UI flags
# Show the "Full workday" filter chip on /camps + /app/camps. Default off
# until enough camp records have hours + extended-care fields populated to
# make the filter useful (~25+ matching camps). Flip to "true" after an
# enrichment pass lifts the match count above that threshold.
NEXT_PUBLIC_ENABLE_FULL_WORKDAY_FILTER=false
